# Google Gemini API Key (Google AI Studio)
# Obtenir une clé sur : https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# App config
APP_NAME=PocketSage
APP_ENV=development
APP_PORT=8000

# Storage (données locales — jamais partagées)
DATA_DIR=./data

# Langue par défaut
DEFAULT_LANG=fr
SUPPORTED_LANGS=fr,en,fon,yo
